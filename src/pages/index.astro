---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const [essayEntries, noteEntries, projectEntries] = await Promise.all([
  getCollection('essays'),
  getCollection('notes'),
  getCollection('projects'),
]);

type Category = 'essay' | 'note' | 'project';

const posts = [
  ...essayEntries.map(p =>   ({ ...p, category: 'essay'   as Category, href: `/essays/${p.id}`   })),
  ...noteEntries.map(p =>    ({ ...p, category: 'note'    as Category, href: `/notes/${p.id}`    })),
  ...projectEntries.map(p => ({ ...p, category: 'project' as Category, href: `/projects/${p.id}` })),
].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10).toUpperCase();
}

const latest = posts[0];
const filters = ['essay', 'note', 'project'] as const;
---

<Base
  title="Anyone Can Cook"
  description="Essays, notes, and side projects."
>
  <h1 class="section-heading">Thoughts</h1>

  <nav class="post-filters" aria-label="Filter posts by type">
    {filters.map(f => (
      <button class="post-filter" data-filter={f}>{f}s</button>
    ))}
  </nav>

  <ul class="post-list">
    {posts.map((post, i) => (
      <li class="post-list-item" data-category={post.category}>
        <a href={post.href}>{post.data.title}</a>
        <span class="post-type-tag">{post.category}</span>
        {i === 0 && <span class="post-list-new">(new)</span>}
      </li>
    ))}
  </ul>

  {latest && (
    <p class="post-list-footer">{formatDate(latest.data.date)}</p>
  )}
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.post-filter');
  const items = document.querySelectorAll<HTMLLIElement>('.post-list-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      const isActive = btn.classList.contains('active');

      if (isActive) {
        btn.classList.remove('active');
        items.forEach(item => item.style.display = '');
      } else {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        items.forEach(item => {
          item.style.display = item.dataset.category === filter ? '' : 'none';
        });
      }
    });
  });
</script>
