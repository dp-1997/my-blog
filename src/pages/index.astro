---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toISOString().slice(0, 10).toUpperCase();
}

const latest = posts[0];
const filters = ['essay', 'note', 'project'] as const;
---

<Base
  title="Damian Pickett"
  description="The personal blog and digital playground of Damian Pickett."
>
  <h1 class="section-heading">Thoughts</h1>

  <nav class="post-filters" aria-label="Filter posts by type">
    {filters.map(f => (
      <button class="post-filter" data-filter={f}>{f}s</button>
    ))}
  </nav>

  <ul class="post-list">
    {posts.map((post, i) => (
      <li class="post-list-item" data-category={post.data.category}>
        <a href={`/posts/${post.id}`}>{post.data.title}</a>
        <span class="post-type-tag">{post.data.category}</span>
        {i === 0 && <span class="post-list-new">(new)</span>}
      </li>
    ))}
  </ul>

  {latest && (
    <p class="post-list-footer">{formatDate(latest.data.date)}</p>
  )}
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.post-filter');
  const items = document.querySelectorAll<HTMLLIElement>('.post-list-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      const isActive = btn.classList.contains('active');

      if (isActive) {
        // Deactivate — show all
        btn.classList.remove('active');
        items.forEach(item => item.style.display = '');
      } else {
        // Activate this filter, deactivate others
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        items.forEach(item => {
          item.style.display = item.dataset.category === filter ? '' : 'none';
        });
      }
    });
  });
</script>
