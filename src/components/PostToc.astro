---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{items.length > 0 && (
  <nav class="toc-root" data-toc aria-label="Table of contents">
    {/* Desktop: always-visible sidebar */}
    <div class="toc-sidebar">
      <p class="toc-label">Table of Contents</p>
      <ol class="toc-list">
        {items.map((h) => (
          <li class={`toc-item toc-item--depth-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </div>

    {/* Mobile: toggle button + dropdown */}
    <button
      class="toc-toggle"
      type="button"
      aria-label="Open table of contents"
      aria-expanded="false"
      aria-controls="toc-panel"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="8" y1="6" x2="21" y2="6"/>
        <line x1="8" y1="12" x2="21" y2="12"/>
        <line x1="8" y1="18" x2="21" y2="18"/>
        <line x1="3" y1="6" x2="3.01" y2="6"/>
        <line x1="3" y1="12" x2="3.01" y2="12"/>
        <line x1="3" y1="18" x2="3.01" y2="18"/>
      </svg>
    </button>

    <div id="toc-panel" class="toc-panel" hidden>
      <p class="toc-label">On this page</p>
      <ol class="toc-list">
        {items.map((h) => (
          <li class={`toc-item toc-item--depth-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </div>
  </nav>
)}

<style>
  /* ── Shared styles ── */
  .toc-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.85rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .toc-item:last-child {
    margin-bottom: 0;
  }

  .toc-item--depth-3 {
    padding-left: 1rem;
  }

  .toc-item a {
    text-decoration: none;
    font-size: 0.78rem;
    color: var(--muted);
    display: block;
    transition: color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--ink);
  }

  .toc-item a.is-active {
    color: var(--ink);
  }

  /* ── Desktop: always-visible sidebar ── */
  .toc-sidebar {
    position: fixed;
    top: 9rem;
    left: calc(50% + 355px);
    width: 200px;
    max-height: calc(100vh - 12rem);
    overflow-y: auto;
  }

  /* Hide mobile elements on desktop */
  .toc-toggle,
  .toc-panel {
    display: none;
  }

  /* ── Mobile: below 1100px, switch to toggle mode ── */
  @media (max-width: 1100px) {
    .toc-sidebar {
      display: none;
    }

    .toc-root {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 50;
    }

    .toc-toggle {
      display: flex;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--ink);
      color: var(--paper);
      border: none;
      cursor: pointer;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 14px var(--shadow);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .toc-toggle:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px var(--shadow);
    }

    .toc-panel {
      display: block;
      position: absolute;
      bottom: calc(100% + 0.75rem);
      right: 0;
      width: 280px;
      max-height: 60vh;
      overflow-y: auto;
      background: var(--paper);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: 1.25rem 1.4rem;
      box-shadow: 0 10px 30px var(--shadow);
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.2s ease, transform 0.2s ease;
      pointer-events: none;
    }

    .toc-panel[hidden] {
      display: none;
    }

    .toc-panel.is-open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }
</style>

<script>
  // Delegated, wired-once listeners: state is derived from the current DOM,
  // so the TOC works across view-transition swaps without any rebinding.
  const w = window as Window & { __tocWired?: boolean };
  if (!w.__tocWired) {
    w.__tocWired = true;
    let closeTimer: number | undefined;

    const parts = () => {
      const root = document.querySelector('[data-toc]');
      if (!root) return null;
      return {
        root,
        btn: root.querySelector('.toc-toggle') as HTMLButtonElement,
        panel: root.querySelector('.toc-panel') as HTMLElement,
      };
    };

    function open(p: NonNullable<ReturnType<typeof parts>>) {
      if (closeTimer) {
        window.clearTimeout(closeTimer);
        closeTimer = undefined;
      }
      p.panel.hidden = false;
      void p.panel.offsetWidth;
      p.panel.classList.add('is-open');
      p.btn.setAttribute('aria-expanded', 'true');
    }

    function close(p: NonNullable<ReturnType<typeof parts>>) {
      const panel = p.panel;
      panel.classList.remove('is-open');
      p.btn.setAttribute('aria-expanded', 'false');
      closeTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, 220);
    }

    const isOpen = (p: NonNullable<ReturnType<typeof parts>>) =>
      p.btn.getAttribute('aria-expanded') === 'true';

    document.addEventListener('click', (e) => {
      const p = parts();
      if (!p || !(e.target instanceof Element)) return;
      if (e.target.closest('.toc-toggle')) {
        isOpen(p) ? close(p) : open(p);
      } else if (e.target.closest('.toc-list a')) {
        // Native fragment navigation handles scroll and focus; just close.
        if (isOpen(p)) close(p);
      } else if (isOpen(p) && !p.root.contains(e.target)) {
        close(p);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const p = parts();
      if (p && isOpen(p)) close(p);
    });

    // ── Active heading tracking (desktop sidebar) ──
    function updateActive() {
      const p = parts();
      if (!p) return;
      const links = p.root.querySelectorAll<HTMLAnchorElement>('.toc-list a');
      let current = '';
      links.forEach((a) => {
        const href = a.getAttribute('href');
        const heading = href ? document.getElementById(href.slice(1)) : null;
        if (heading && heading.getBoundingClientRect().top <= 120) {
          current = heading.id;
        }
      });
      links.forEach((a) => {
        a.classList.toggle('is-active', a.getAttribute('href') === `#${current}`);
      });
    }

    window.addEventListener('scroll', updateActive, { passive: true });
    document.addEventListener('astro:page-load', updateActive);
    updateActive();
  }
</script>
