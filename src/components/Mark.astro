---
// The site's mark: a mind, thoughts rising.
// Carried over from the first version of the site — refined, not replaced.
interface Props {
  size?: number;
}

const { size = 26 } = Astro.props;
---

<svg
  class="mark"
  viewBox="0 0 44 44"
  width={size}
  height={size}
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="22" cy="24" r="1.7" class="p p1" fill="currentColor" />
  <circle cx="13" cy="19" r="1.3" class="p p2" fill="var(--accent)" />
  <circle cx="31" cy="19" r="1.4" class="p p3" fill="currentColor" />
  <circle cx="22" cy="12" r="1.5" class="p p4" fill="var(--accent)" />
  <circle cx="10" cy="8"  r="1.0" class="p p5" fill="currentColor" />
  <circle cx="33" cy="7"  r="1.1" class="p p6" fill="var(--accent)" />
  <circle cx="22" cy="35" r="7" fill="var(--accent)" />
</svg>
