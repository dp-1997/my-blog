---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Mark from '../components/Mark.astro';
import Sparks from '../components/Sparks.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Damian Pickett — product marketer and maker. Anyone Can Cook is his personal site: selected work, writing, and experiments.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL('/og-image.png', Astro.site).toString();

const path = Astro.url.pathname;
const navItems = [
  { href: '/work/', label: 'Work' },
  { href: '/writing/', label: 'Writing' },
  { href: '/about/', label: 'About' },
  { href: '/cv/', label: 'CV' },
];

function isCurrent(href: string): boolean {
  if (href === '/work/') return path.startsWith('/work');
  if (href === '/writing/')
    return path.startsWith('/writing') || path.startsWith('/essays') || path.startsWith('/notes');
  return path === href || path === href.replace(/\/$/, '');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Anyone Can Cook" href="/rss.xml" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Anyone Can Cook" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <ClientRouter />

    <!-- Set theme before paint to avoid FOUC (default = light), and re-apply
         after view-transition swaps, which reset <html> attributes. -->
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            if (localStorage.getItem('theme') === 'dark') {
              document.documentElement.setAttribute('data-theme', 'dark');
            } else {
              document.documentElement.removeAttribute('data-theme');
            }
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body>
    <Sparks />
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <a href="/" class="nameplate">
        <Mark size={26} />
        <span class="label">Anyone Can Cook</span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        {navItems.map((item) => (
          <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
        <button class="theme-toggle" type="button" aria-label="Dark theme" aria-pressed="false">
          <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
          </svg>
        </button>
      </nav>
    </header>

    <script>
      // One delegated, wired-once listener: view transitions swap the button
      // on every navigation, and scripts may re-execute — delegation plus the
      // guard make both irrelevant. aria-pressed re-syncs on each arrival.
      const w = window as Window & { __themeWired?: boolean };
      if (!w.__themeWired) {
        w.__themeWired = true;
        const root = document.documentElement;
        const reflect = () =>
          document.querySelector('.theme-toggle')
            ?.setAttribute('aria-pressed', String(root.getAttribute('data-theme') === 'dark'));
        document.addEventListener('click', (e) => {
          if (!(e.target instanceof Element) || !e.target.closest('.theme-toggle')) return;
          const isDark = root.getAttribute('data-theme') === 'dark';
          if (isDark) {
            root.removeAttribute('data-theme');
            try { localStorage.setItem('theme', 'light'); } catch (err) {}
          } else {
            root.setAttribute('data-theme', 'dark');
            try { localStorage.setItem('theme', 'dark'); } catch (err) {}
          }
          reflect();
        });
        reflect();
        document.addEventListener('astro:page-load', reflect);
      }
    </script>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <p class="colophon">
        Anyone Can Cook is the personal site of Damian Pickett — named for
        <a href="/essays/anyone-can-cook/">the closing line of a film about a rat who cooks</a>.
        Set in Newsreader and JetBrains Mono. Designed and built by hand, with Claude.
      </p>
      <nav class="footer-links" aria-label="Contact and social links">
        <a href="mailto:damianpickett1997@gmail.com">Email</a>
        <a href="https://www.linkedin.com/in/damianpickett97" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://x.com/DamianPickett_" target="_blank" rel="noopener noreferrer">X</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </footer>
  </body>
</html>
